# Postgres: em Docker Compose use host `db`; com backend na máquina use `localhost` (porta 5432).
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/meu_banco

ACCESS_TOKEN_EXPIRE_MINUTES=
REFRESH_TOKEN_EXPIRE_DAYS=
SECRET_KEY=

MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_FROM_NAME=Rota UEFS Notificações

BASE_URL_FRONTEND=http://localhost:3000

# Obrigatório em produção; em dev o backend usa um default se omitido.
REGISTRATION_CODE_SECRET=
