# https://editorconfig.org
# Evita problemas de encoding (ex.: texto PT-BR quebrado como "sessÃ£o") ao padronizar UTF-8.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,jsx,ts,tsx,mjs,cjs,css,scss,json,yml,yaml,html}]
indent_style = space
indent_size = 2

[*.py]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false
